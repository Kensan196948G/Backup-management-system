-+++            -m "" \
-+++            -m "- Black: コードフォーマット" \
-+++            -m "- isort: import文の整理" \
-+++            -m "- autoflake: 未使用import削除" \
-+++            -m "" \
-+++            -m "Co-Authored-By: Claude Auto Repair <noreply@anthropic.com>"
-+++          
-+++          # ブランチ名を取得してpush
-+++          if [ "${{ github.event_name }}" = "pull_request" ]; then
-+++            BRANCH_NAME="${{ github.head_ref }}"
