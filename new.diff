-++    update_last_error "$CURRENT_ERROR"
-++    
-++    REPAIR_COUNT=$(get_repair_count)
-++    log "📊 修復回数更新: $REPAIR_COUNT / $MAX_REPAIR"
-++    
-++    # 再レビュー実行
