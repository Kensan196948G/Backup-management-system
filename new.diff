--++name: Claude Auto Repair Loop
--++
--++on:
--++  # PR作成時・更新時に実行（botコミットによる再トリガーを除外）
--++  pull_request:
--++    types: [opened, synchronize, reopened]
--++    branches: [main, develop]
--++
--++  # 手動実行のみ（push triggerは自動コミットによる無限チェーンを防ぐため削除）
--++  workflow_dispatch:
--++    inputs:
--++      max_repairs:
--++        description: '最大修復回数（デフォルト: 3）'
--++        required: false
--++        default: '3'
--++        type: string
--++
--++# 同一ブランチへの並列実行を防止（競合・二重修復防止）
--++concurrency:
--++  group: auto-repair-${{ github.ref }}
--++  cancel-in-progress: false
--++
--++jobs:
--++  claude-review-and-repair:
--++    name: Claude Review & Auto Repair
--++    runs-on: ubuntu-latest
--++
--++    # botによる自動コミットが再トリガーしないようにスキップ
--++    if: |
--++      github.actor != 'github-actions[bot]' &&
--++      github.actor != 'claude-auto-repair[bot]' &&
--++      !contains(github.event.head_commit.message, '🤖 自動修復')
--++
--++    permissions:
--++      contents: write
--++      pull-requests: write
--++      issues: write
--++
--++    steps:
--++      # ========================================
--++      # 1. チェックアウト
--++      # ========================================
--++      - name: Checkout code
--++        uses: actions/checkout@v4
--++        with:
--++          fetch-depth: 0  # 完全な履歴を取得（差分比較用）
--++          # push/PR両対応: head_refが空のpushイベントではデフォルトrefを使用
--++          ref: ${{ github.head_ref || github.ref }}
--++
--++      # ========================================
--++      # 2. Python環境セットアップ
--++      # ========================================
--++      - name: Set up Python
--++        uses: actions/setup-python@v5
--++        with:
--++          python-version: '3.11'
--++
--++      - name: Install dependencies
--++        run: |
--++          python -m pip install --upgrade pip
--++          # jqはCLIツールのためaptで導入（pip install jqではCLIは使えない）
--++          sudo apt-get install -y jq
--++          # autoflakeをsetupステップで事前インストール
--++          pip install autoflake
--++          if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
--++
--++      # ========================================
--++      # 3. 状態管理の初期化（Cacheで前回runの状態を引き継ぎ）
--++      # ========================================
--++      - name: Restore repair state from cache
--++        uses: actions/cache@v4
--++        with:
--++          path: state.json
--++          # ブランチ単位でstateを保持（runをまたいでrepair_countを維持）
--++          key: auto-repair-state-${{ github.ref }}-${{ github.sha }}
--++          restore-keys: |
--++            auto-repair-state-${{ github.ref }}-
--++
--++      - name: Initialize repair state
