--++
--++```bash
--++# 構文チェック
--++bash -n scripts/local-auto-repair.sh
--++# エラーがなければOK ✅
--++
--++# state.json の初期化確認
--++cat state.json
--++# JSON形式で表示されればOK ✅
--++```
