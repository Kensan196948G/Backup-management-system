-++            # if [[ $REPLY =~ ^[Yy]$ ]]; then
-++            #     git add .
-++            #     git commit -m "Auto repair: 自動修復完了"
-++            #     log "✅ 自動コミット完了"
-++            # fi
-++        fi
-++        
-++        reset_state
