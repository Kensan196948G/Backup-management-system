-+++              }
-+++            } else {
-+++              body += `- 自動修復: ${reviewResult === 'OK' ? '不要' : '❌ 失敗または変更なし'}\n\n`;
-+++            }
-+++            
-+++            if (currentCount >= maxRepairs) {
-+++              body += '\n### 🚨 修復回数上限到達\n\n';
